{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/f1-proxy", "destination": "/api/f1-proxy.js" },
    { "source": "/api/news", "destination": "/api/news.js" },
    { "source": "/api/ergast/(.*)", "destination": "/api/f1-proxy.js?endpoint=ergast&path=$1" },
    { "source": "/api/openf1/(.*)", "destination": "/api/f1-proxy.js?endpoint=openf1&path=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
